FROM python:3.11-slim

WORKDIR /app

# Install system dependencies (for OpenCV, ReportLab, etc.)
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    libjpeg-dev \
    fonts-dejavu \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Create cache directory for projects
RUN mkdir -p /tmp/passport_creator/users
RUN chmod -R 777 /tmp/passport_creator

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
